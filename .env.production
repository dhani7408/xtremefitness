# Production environment template
# Do NOT commit real secrets. Prefer setting these in Vercel Environment Variables.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gymdb?schema=public"
NEXTAUTH_SECRET="replace-with-strong-random-secret"
NEXTAUTH_URL="https://your-domain.vercel.app"

# WhatsApp (if enabled)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# ESSL device push key
ESSL_DEVICE_KEY="replace-with-production-key"
